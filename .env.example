# Copy this file to `.env.development` (staging Supabase)
# or `.env.production` (prod Supabase) and fill in the values.
# Never commit a real .env file — the .gitignore already blocks it.

# Supabase project URL — https://<project-ref>.supabase.co
VITE_SUPABASE_URL=

# Supabase anon key — safe to ship with the client (RLS enforces access).
# Find it in: Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=
